# Required QQBot credentials
QQ_BOT_APP_ID=
QQ_BOT_SECRET=

# Optional pre-issued bot token. Leave empty to fetch app access tokens automatically.
QQ_BOT_TOKEN=

# Transport: auto, webhook, or websocket.
QQ_BOT_TRANSPORT=auto
QQ_BOT_WEBHOOK_URL=https://example.com/qqbot/webhook
QQ_BOT_GATEWAY_URL=

# Runtime options
QQ_BOT_SANDBOX=false
QQ_BOT_INTENTS=1174409216
QQ_BOT_USER_NAME=qqbot

# Advanced endpoint overrides
QQ_BOT_API_BASE_URL=
QQ_BOT_TOKEN_URL=https://bots.qq.com/app/getAppAccessToken
